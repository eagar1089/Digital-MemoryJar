# Digital Memory Jar Backend Configuration
# Copy this file to .env and fill in your values

# MongoDB Connection
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/dmj?retryWrites=true&w=majority"
COLLECTION_NAME="dmj"

# Firebase Admin SDK (for backend verification)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"

# Hugging Face API (for NLP/AI features)
HF_API_TOKEN="hf_xxxxxxxxxxxx"
HF_INFERENCE_TIMEOUT_SECONDS="30"

# NLP Processing Configuration
ENABLE_NLP_SCHEDULER="true"
NLP_SCHEDULER_INTERVAL_SECONDS="30"
KEYBERT_TOP_N="8"
TOPIC_MIN_SCORE="0.2"
TOPIC_MAX_LABELS="2"

# Spotify Integration (optional)
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
SPOTIFY_MARKET="US"

# CORS Configuration
CORS_ALLOW_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Deployment
PORT="8000"
ENVIRONMENT="development"
